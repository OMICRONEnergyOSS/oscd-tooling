{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "noEmitOnError": true,
    "moduleResolution": "bundler",
    "lib": [
      "es2021",
      "dom"
    ],
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "mocha"
    ],
    "typeRoots": [
      "../node_modules/@types"
    ],
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "sourceMap": true,
    "inlineSources": true,
    "declaration": true,
    "skipLibCheck": true
  }
}
